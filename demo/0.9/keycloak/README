# To start Keycloak with RBOC
# use this volume in docker compose
    volumes:
      - ./almondmonitor-realm.json.ropc:/opt/keycloak/data/import/keycloak-realm.json
# To use Keycloak AuthFlow use this
    volumes:
      - ./almondmonitor-realm.json:/opt/keycloak/data/import/keycloak-realm.json
#####
# Start Keycloak
docker compose up -d
#
# Start an Almond Monitor instance
docker run --rm --platform linux/amd64 --net almond-demo --name almond_keycloak -d -p 8015:80 -p 9015:90 andreaslindell72/almond-monitor:latest
#
# Stop Keycloak
docker compose down -v
